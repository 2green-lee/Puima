{
  "entities": {
    "Post": {
      "title": "Class Post",
      "description": "A class or product listing on the main grid.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the class" },
        "visuals": { "type": "string", "description": "Description of visuals or category" },
        "image": { "type": "string", "description": "URL of the image (or path)" },
        "naverUrl": { "type": "string", "description": "Link to Naver store" },
        "originalPrice": { "type": "string", "description": "Original price (optional)" },
        "price": { "type": "string", "description": "Current price" },
        "rating": { "type": "string", "description": "Rating out of 5" },
        "reviews": { "type": "string", "description": "Number of reviews" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price", "naverUrl"]
    },
    "User": {
      "title": "User Profile",
      "description": "Information about the application user.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "Question": {
      "title": "Question",
      "description": "Student questions and answers.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the question" },
        "reference": { "type": "string", "description": "Reference video/course name" },
        "content": { "type": "string", "description": "Content of the question" },
        "authorId": { "type": "string", "description": "Author UID" },
        "authorEmail": { "type": "string", "description": "Author email address" },
        "authorName": { "type": "string", "description": "Author display name" },
        "isPrivate": { "type": "boolean", "description": "Is question private" },
        "createdAt": { "type": "string", "format": "date-time" },
        "answer": { "type": "string", "description": "Admin answer content" },
        "answeredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "authorId", "isPrivate", "createdAt"]
    },
    "Chapter": {
      "title": "Course Chapter",
      "description": "A video lecture belonging to a specific class.",
      "type": "object",
      "properties": {
        "chapterNo": { "type": "string", "description": "Chapter number sequence (01, 02)" },
        "title": { "type": "string", "description": "Title of the chapter" },
        "duration": { "type": "string", "description": "Chapter lecture time duration like '45분 분량'" },
        "videoUrl": { "type": "string", "description": "URL of the lecture video stream" },
        "milestones": {
          "type": "array",
          "description": "Internal keypoints of the video with durations",
          "items": {
            "type": "object",
            "properties": {
              "timeLabel": { "type": "string" },
              "seconds": { "type": "integer" },
              "title": { "type": "string" },
              "desc": { "type": "string" }
            }
          }
        },
        "order": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chapterNo", "title", "videoUrl"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection of all class posts"
    },
    "/posts/{postId}/chapters/{chapterId}": {
      "schema": "Chapter",
      "description": "Subcollection of chapters under each class post"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/questions/{questionId}": {
      "schema": "Question",
      "description": "Collection of Q&As"
    }
  }
}
