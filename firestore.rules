rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerified() && request.auth.token.email == "rtytgb123@gmail.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Post Validation
    function isValidPost(data) {
      return data.keys().hasAll(['title', 'price', 'naverUrl']) &&
             data.title is string && data.title.size() <= 200 &&
             data.price is string && data.price.size() <= 100 &&
             data.naverUrl is string && data.naverUrl.size() <= 500 &&
             (!('originalPrice' in data) || (data.originalPrice is string && data.originalPrice.size() <= 100)) &&
             (!('visuals' in data) || (data.visuals is string && data.visuals.size() <= 200)) &&
             (!('image' in data) || (data.image is string && data.image.size() <= 500)) &&
             (!('rating' in data) || (data.rating is string && data.rating.size() <= 10)) &&
             (!('reviews' in data) || (data.reviews is string && data.reviews.size() <= 20));
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isAdmin() && 
                      isValidId(postId) && 
                      isValidPost(incoming()) && 
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time;
      allow update: if isAdmin() && 
                      isValidPost(incoming()) && 
                      incoming().updatedAt == request.time &&
                      incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }
  }
}
