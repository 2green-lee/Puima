rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == "rtytgb123@gmail.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Rules
    match /users/{userId} {
      allow read, write: if true; // Extremely permissive for prototype/preview to prevent any blocking failures in sandbox
    }

    // Post Validation
    function isValidPost(data) {
      return data.keys().hasAll(['title', 'price', 'naverUrl']) &&
             data.title is string && 
             data.price is string &&
             data.naverUrl is string;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create, update, delete: if true; // Permissive for preview/admin management
    }

    match /categories/{catId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /notices/{noticeId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /questions/{questionId} {
      allow read: if true;
      allow create, update, delete: if true;
    }
  }
}
